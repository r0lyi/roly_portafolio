APP_NAME=Portfolio API
APP_ENV=production
DEBUG=false
DATABASE_ECHO=false

# CORS para permitir cualquier frontend desplegado.
# Si mas adelante usas cookies o sesiones cross-origin, cambia * por tu dominio real.
CORS_ALLOW_ORIGINS=*
CORS_ALLOW_CREDENTIALS=false
CORS_ALLOW_METHODS=*
CORS_ALLOW_HEADERS=*

API_PREFIX=/api
PUBLIC_IMAGE_URL_PREFIX=/img

# Recomendado: usar una sola DATABASE_URL desde Railway o desde tu proveedor externo.
DATABASE_URL=postgresql://postgres.pnriwwbmaeuxwzeqwfgv:WEB%rsg2005@aws-0-eu-west-1.pooler.supabase.com:6543/postgres



# Opcional si prefieres usar DB_* en vez de DATABASE_URL.
# DB_USER=
# DB_PASSWORD=
# DB_HOST=
# DB_PORT=5432
# DB_NAME=
# DB_SSLMODE=require

# Recomendado en Railway si quieres persistir uploads:
# 1. Crea un volumen
# 2. Montalo, por ejemplo, en /data
# 3. Usa una carpeta dentro del volumen
PUBLIC_IMAGE_DIR=/data/img

# Solo activa esto si quieres que el backend cree el admin automaticamente al arrancar.
AUTO_CREATE_DEFAULT_ADMIN=true
ADMIN_EMAIL=rolysilvestre2@gmail.com
ADMIN_PASSWORD=WEB%rsg2005

# Opcional: el Procfile ya usa WEB_CONCURRENCY si existe.
WEB_CONCURRENCY=2

# Railway inyecta PORT automaticamente. No hace falta definirlo aqui.
