APP_NAME=Portfolio API
APP_ENV=local
API_PREFIX=/api
CORS_ALLOW_ORIGINS=http://localhost:5173,http://127.0.0.1:5173
CORS_ALLOW_CREDENTIALS=false
CORS_ALLOW_METHODS=*
CORS_ALLOW_HEADERS=*
PUBLIC_IMAGE_URL_PREFIX=/img
PUBLIC_IMAGE_DIR=
DEBUG=true
DATABASE_ECHO=true

# Usa DATABASE_URL o las variables DB_*.
DATABASE_URL=
DB_USER=portfolio_user
DB_PASSWORD=change-me-local
DB_HOST=localhost
DB_PORT=5432
DB_NAME=portfolio_db
DB_SSLMODE=

AUTO_CREATE_DEFAULT_ADMIN=true
ADMIN_EMAIL=admin@local.test
ADMIN_PASSWORD=change-me-local
