# Copia este archivo a .env y ajusta los valores segun el entorno.
# Local:
# - APP_ENV=local
# - DEBUG=true
# - CORS_ALLOW_ORIGINS=http://localhost:5173,http://127.0.0.1:5173
# - PUBLIC_IMAGE_DIR=  (vacio para usar ../frontend/public/img)
#
# Deploy / Railway:
# - APP_ENV=production
# - DEBUG=false
# - CORS_ALLOW_ORIGINS=*   o tu dominio real si prefieres restringirlo
# - PUBLIC_IMAGE_DIR=/data/img   si montas un volumen para persistir uploads

APP_NAME=Portfolio API
APP_ENV=local
DEBUG=true
DATABASE_ECHO=true

API_PREFIX=/api
PUBLIC_IMAGE_URL_PREFIX=/img
PUBLIC_IMAGE_DIR=

CORS_ALLOW_ORIGINS=http://localhost:5173,http://127.0.0.1:5173
CORS_ALLOW_CREDENTIALS=false
CORS_ALLOW_METHODS=*
CORS_ALLOW_HEADERS=*

# Recomendado en deploy: usar una sola DATABASE_URL.
DATABASE_URL=

# Alternativa si no usas DATABASE_URL.
DB_USER=portfolio_user
DB_PASSWORD=usuario1
DB_HOST=localhost
DB_PORT=5432
DB_NAME=portfolio_db
=

# Activalo solo si quieres crear el admin automaticamente al arrancar.
AUTO_CREATE_DEFAULT_ADMIN=true
ADMIN_EMAIL=admin@local.test
ADMIN_PASSWORD=change-me-local
