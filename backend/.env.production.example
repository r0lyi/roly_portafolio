APP_ENV=production
DEBUG=false
DATABASE_ECHO=false
CORS_ALLOW_ORIGINS=*
CORS_ALLOW_CREDENTIALS=false
CORS_ALLOW_METHODS=*
CORS_ALLOW_HEADERS=*
PUBLIC_IMAGE_DIR=

# Recomendado en produccion:
DATABASE_URL=postgresql+psycopg2://user:password@db-host:5432/portfolio_db
# Si prefieres DB_* en lugar de DATABASE_URL, puedes activar SSL asi:
# DB_SSLMODE=require

# Solo activalo si realmente quieres crear el admin automaticamente.
AUTO_CREATE_DEFAULT_ADMIN=false
ADMIN_EMAIL=admin@company.com
ADMIN_PASSWORD=replace-with-a-secure-password
